---
import BaseLayout from "../layouts/BaseLayout.astro";
import SeasonalHero from "../components/SeasonalHero.astro";
import { getCollection, getEntry } from "astro:content";
import { BASE_PATH } from "../consts";
import { getSiteSettings } from "../site-settings";

// CMS管理のHome文言とサイト設定を取得する
const homeEntry = await getEntry("home", "home");
if (!homeEntry) {
  throw new Error("Home文言（src/content/pages/home.yaml）が見つかりません");
}
const home = homeEntry.data;
const site = await getSiteSettings();

// GitHubリンクの表示テキストはURLから導出する（URLだけ変更されて表示が古く残ることを防ぐ）
const githubLabel = site.social.github.replace(/^https?:\/\//, "");

// 制作セクションに抜粋する最新の制作（draft除外・pubDate降順の先頭2件）
const recentWorks = (await getCollection("works"))
  .filter((work) => !work.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout title="Home" description={site.description}>
  <SeasonalHero slot="hero" season="auto" height="70vh">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-role">{home.hero.role}</p>
        <h1 class="hero-name">{site.author}</h1>
        <span class="hero-rule" aria-hidden="true"></span>
        <p class="hero-copy">{home.hero.tagline}</p>
      </div>
    </div>
  </SeasonalHero>

  <p class="home-intro" data-reveal>
    {home.intro.text}
    <a class="home-intro-link" href={`${BASE_PATH}about/`}>{home.intro.linkLabel}<span class="arrow" aria-hidden="true">→</span></a>
  </p>

  <section class="home-section">
    <h2 class="section-heading" data-reveal>
      <span class="section-num">壱</span>
      <span class="section-title">制作</span>
      <span class="section-label" aria-hidden="true">WORKS</span>
    </h2>
    {recentWorks.length > 0 ? (
      <ul class="works-list" role="list" data-reveal="delayed">
        {recentWorks.map((work) => (
          <li>
            <a class="works-link" href={`${BASE_PATH}works/${work.id}/`}>
              <span class="works-title">{work.data.title}</span>
              <span class="works-desc">{work.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="works-empty" data-reveal="delayed">公開できる制作を準備中です。</p>
    )}
    <a class="section-more" href={`${BASE_PATH}works/`} data-reveal="delayed">
      制作をすべて見る<span class="arrow" aria-hidden="true">→</span>
    </a>
  </section>

  <section class="home-section">
    <h2 class="section-heading" data-reveal>
      <span class="section-num">弐</span>
      <span class="section-title">技術</span>
      <span class="section-label" aria-hidden="true">SKILLS</span>
    </h2>
    <ul class="skill-list" role="list" data-reveal="delayed">
      {home.skills.map((skill) => <li>{skill}</li>)}
    </ul>
  </section>

  <section class="home-section">
    <h2 class="section-heading" data-reveal>
      <span class="section-num">参</span>
      <span class="section-title">連絡先</span>
      <span class="section-label" aria-hidden="true">CONTACT</span>
    </h2>
    <ul class="contact-list" role="list" data-reveal="delayed">
      {site.social.github && (
        <li>
          <span class="contact-label">GITHUB</span>
          <a href={site.social.github} target="_blank" rel="noopener noreferrer">{githubLabel}</a>
        </li>
      )}
      <li>
        <span class="contact-label">EMAIL</span>
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </li>
    </ul>
  </section>
</BaseLayout>
