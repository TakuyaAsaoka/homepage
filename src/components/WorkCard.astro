---
import TagList from "./TagList.astro";
import { BASE_PATH } from "../consts";

interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
}

const { title, description, tags, slug } = Astro.props;
---

<article class="work-card">
  <h3>
    <a href={`${BASE_PATH}works/${slug}/`}>{title}</a>
  </h3>
  <p>{description}</p>
  <TagList tags={tags} />
</article>

<style>
  .work-card {
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  .work-card h3 a {
    text-decoration: none;
    color: inherit;
  }
  .work-card :global(.tags) {
    margin-top: 0.5rem;
  }
</style>
