---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagList from "../../components/TagList.astro";
import { getCollection, render } from "astro:content";
import { BASE_PATH, SITE_LOCALE } from "../../consts";

export async function getStaticPaths() {
  const works = await getCollection("works");
  return works
    .filter((work) => !work.data.draft)
    .map((work) => ({
      params: { slug: work.id },
      props: { work },
    }));
}

const { work } = Astro.props;
const { Content } = await render(work);
---

<BaseLayout
  title={work.data.title}
  description={work.data.description}
  breadcrumb={[
    { label: "Works", href: `${BASE_PATH}works/` },
    { label: work.data.title },
  ]}
  article={{
    datePublished: work.data.pubDate,
    keywords: work.data.tags,
    image: work.data.image,
  }}
>
  <article>
    <h1>{work.data.title}</h1>
    <time datetime={work.data.pubDate.toISOString()}>
      {work.data.pubDate.toLocaleDateString(SITE_LOCALE)}
    </time>
    <TagList tags={work.data.tags} />
    {work.data.url && (
      <p><a href={work.data.url} target="_blank" rel="noopener noreferrer">制作を見る</a></p>
    )}
    <div class="content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  time {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  article :global(.tags) {
    margin: 0.5rem 0;
  }
  .content {
    margin-top: 2rem;
  }
  /* Markdown本文の縦リズム（グローバルリセットで消えた余白を戻す） */
  .content :global(p) {
    margin-block: 1em;
  }
  .content :global(ul),
  .content :global(ol) {
    margin-block: 1em;
    padding-left: 1.5em;
  }
  .content :global(li) {
    margin-block: 0.4em;
  }
  .content :global(h2),
  .content :global(h3) {
    margin-block: 1.5em 0.75em;
  }
</style>
