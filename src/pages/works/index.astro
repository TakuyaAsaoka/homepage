---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkCard from "../../components/WorkCard.astro";
import { getPublishedWorks } from "../../works";

const works = await getPublishedWorks();
---

<BaseLayout title="Works" description="アサオカの制作一覧" breadcrumb={[{ label: "Works" }]}>
  <section>
    <h1 class="section-heading page-heading">
      <span class="section-title">制作</span>
      <span class="section-label" aria-hidden="true">WORKS</span>
    </h1>
    {works.length > 0 ? (
      works.map((work) => (
        <WorkCard
          title={work.data.title}
          description={work.data.description}
          tags={work.data.tags}
          slug={work.id}
        />
      ))
    ) : (
      <p>公開できる制作を準備中です。</p>
    )}
  </section>
</BaseLayout>
