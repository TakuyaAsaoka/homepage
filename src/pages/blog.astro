---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_LOCALE } from "../consts";
import { fetchFeedItems } from "../rss";
import { getSiteSettings } from "../site-settings";

const site = await getSiteSettings();

// note のプロフィールURL（RSS取得失敗時の代替導線に使う）
const noteProfileUrl = site.noteRssUrl.replace(/\/rss\/?$/, "");

// RSS URL が設定済みかの真偽値。空判定はこの変数に集約し、
// フロントマター・テンプレート全体で同一パターンに統一する
const hasRssUrl = site.noteRssUrl !== "";

const { items: feedItems, failed: fetchFailed } = hasRssUrl
  ? await fetchFeedItems(site.noteRssUrl)
  : { items: [], failed: false };
---

<BaseLayout title="Blog" description="noteに書いた記事の一覧" breadcrumb={[{ label: "Blog" }]}>
  <section>
    <h1 class="section-heading page-heading">
      <span class="section-title">記事</span>
      <span class="section-label" aria-hidden="true">BLOG</span>
    </h1>
    {!hasRssUrl && (
      <p>サイト設定の「note RSS URL」を設定すると記事が表示されます。</p>
    )}
    {feedItems.length > 0 ? (
      <ul class="blog-list">
        {feedItems.map((item) => (
          <li>
            <a href={item.link} target="_blank" rel="noopener noreferrer">
              {item.title}
            </a>
            {item.pubDate && (
              <time datetime={new Date(item.pubDate).toISOString()}>
                {new Date(item.pubDate).toLocaleDateString(SITE_LOCALE)}
              </time>
            )}
          </li>
        ))}
      </ul>
    ) : fetchFailed ? (
      <p>記事を読み込めませんでした。<a href={noteProfileUrl} target="_blank" rel="noopener noreferrer">note</a>で直接ご覧いただけます。</p>
    ) : hasRssUrl && (
      <p>まだ記事がありません。</p>
    )}
  </section>
</BaseLayout>

<style>
  .blog-list {
    list-style: none;
  }
  .blog-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .blog-list time {
    font-size: 0.85rem;
    white-space: nowrap;
    color: var(--color-muted);
  }
</style>
