---
import BaseLayout from "../layouts/BaseLayout.astro";
import SeasonalHero from "../components/SeasonalHero.astro";
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, SOCIAL_LINKS, EMAIL, SITE_AUTHOR, BASE_PATH } from "../consts";

// スキルセクションに表示する技術タグ
const skills = [
  "TypeScript",
  "React",
  "Node.js",
  "AWS",
  "Kubernetes",
  "Terraform",
  "Grafana",
  "Prometheus",
];

// 制作セクションに抜粋する最新プロジェクト（draft除外・pubDate降順の先頭2件）
const recentProjects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout title="Home" description={SITE_DESCRIPTION}>
  <div class="home-hero">
    <SeasonalHero season="auto" height="70vh">
      <div class="hero-content">
        <p class="hero-role">SOFTWARE ENGINEER / SRE</p>
        <h1 class="hero-name">{SITE_AUTHOR}</h1>
        <span class="hero-rule" aria-hidden="true"></span>
        <p class="hero-copy">つくることと、動かし続けること。</p>
      </div>
    </SeasonalHero>
  </div>

  <p class="home-intro" data-reveal>
    自動車業界で、つくって動かし続ける仕事をしています。
    <a class="home-intro-link" href={`${BASE_PATH}about/`}>わたしについて<span class="arrow" aria-hidden="true">→</span></a>
  </p>

  <section class="home-section">
    <h2 class="section-heading" data-reveal>
      <span class="section-num">壱</span>
      <span class="section-title">制作</span>
      <span class="section-label" aria-hidden="true">WORKS</span>
    </h2>
    {recentProjects.length > 0 ? (
      <ul class="works-list" role="list" data-reveal="delayed">
        {recentProjects.map((project) => (
          <li>
            <a class="works-link" href={`${BASE_PATH}projects/${project.id}/`}>
              <span class="works-title">{project.data.title}</span>
              <span class="works-desc">{project.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="works-empty" data-reveal="delayed">公開できる制作物を準備中です。</p>
    )}
    <a class="section-more" href={`${BASE_PATH}projects/`} data-reveal="delayed">
      制作をすべて見る<span class="arrow" aria-hidden="true">→</span>
    </a>
  </section>

  <section class="home-section">
    <h2 class="section-heading" data-reveal>
      <span class="section-num">弐</span>
      <span class="section-title">技術</span>
      <span class="section-label" aria-hidden="true">SKILLS</span>
    </h2>
    <ul class="skill-list" role="list" data-reveal="delayed">
      {skills.map((skill) => <li>{skill}</li>)}
    </ul>
  </section>

  <section class="home-section">
    <h2 class="section-heading" data-reveal>
      <span class="section-num">参</span>
      <span class="section-title">連絡先</span>
      <span class="section-label" aria-hidden="true">CONTACT</span>
    </h2>
    <ul class="contact-list" role="list" data-reveal="delayed">
      <li>
        <span class="contact-label">GITHUB</span>
        <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer">github.com/TakuyaAsaoka</a>
      </li>
      <li>
        <span class="contact-label">EMAIL</span>
        <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
      </li>
    </ul>
  </section>
</BaseLayout>
