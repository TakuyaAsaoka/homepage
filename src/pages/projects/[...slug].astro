---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagList from "../../components/TagList.astro";
import { getCollection, render } from "astro:content";
import { BASE_PATH, SITE_LOCALE } from "../../consts";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects
    .filter((p) => !p.data.draft)
    .map((project) => ({
      params: { slug: project.id },
      props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  breadcrumb={[
    { label: "Projects", href: `${BASE_PATH}projects/` },
    { label: project.data.title },
  ]}
  article={{
    datePublished: project.data.pubDate,
    keywords: project.data.tags,
    image: project.data.image,
  }}
>
  <article>
    <h1>{project.data.title}</h1>
    <time datetime={project.data.pubDate.toISOString()}>
      {project.data.pubDate.toLocaleDateString(SITE_LOCALE)}
    </time>
    <TagList tags={project.data.tags} />
    {project.data.url && (
      <p><a href={project.data.url} target="_blank" rel="noopener noreferrer">プロジェクトを見る</a></p>
    )}
    <div class="content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  time {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  article :global(.tags) {
    margin: 0.5rem 0;
  }
  .content {
    margin-top: 2rem;
  }
  /* Markdown本文の縦リズム（グローバルリセットで消えた余白を戻す） */
  .content :global(p) {
    margin-block: 1em;
  }
  .content :global(ul),
  .content :global(ol) {
    margin-block: 1em;
    padding-left: 1.5em;
  }
  .content :global(li) {
    margin-block: 0.4em;
  }
  .content :global(h2),
  .content :global(h3) {
    margin-block: 1.5em 0.75em;
  }
</style>
