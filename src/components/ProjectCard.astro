---
import TagList from "./TagList.astro";

interface Props {
  title: string;
  description: string;
  tags: string[];
  url?: string;
  slug: string;
}

const { title, description, tags, slug } = Astro.props;
---

<article class="project-card">
  <h3>
    <a href={`${import.meta.env.BASE_URL}projects/${slug}/`}>{title}</a>
  </h3>
  <p>{description}</p>
  <TagList tags={tags} />
</article>

<style>
  .project-card {
    padding: 1rem;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  .project-card h3 a {
    text-decoration: none;
    color: inherit;
  }
  .project-card :global(.tags) {
    margin-top: 0.5rem;
  }
</style>
