---
import { ClientRouter } from "astro:transitions";

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb, { type BreadcrumbItem } from "../components/Breadcrumb.astro";
import { type ArticleData } from "../components/StructuredData.astro";
import { SITE_LANG } from "../consts";
import { MONTH_SEASONS } from "../season";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  // Home を除くパンくず階層。省略時はパンくず非表示（Home・404 は渡さない）
  breadcrumb?: BreadcrumbItem[];
  // JSON-LD（Article）用の記事情報。制作詳細ページのみ渡す
  article?: ArticleData;
}

const { title, description, image, noindex, breadcrumb, article } = Astro.props;
---

<!doctype html>
<html lang={SITE_LANG}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
      breadcrumb={breadcrumb}
      article={article}
    />
    <ClientRouter />
    <script is:inline define:vars={{ monthSeasons: MONTH_SEASONS }}>
      // html に季節連動の data-season と、js / reduced-motion フラグを付与する。
      // ClientRouter の遷移では <html> の属性・クラスが遷移先ドキュメント（フラグ未設定）で
      // 置換されるため、初回ペイント前の実行に加え astro:after-swap でも再適用する。
      // 季節マッピングは src/season.ts が単一情報源。is:inline は import 不可のため、
      // define:vars で MONTH_SEASONS（月→季節の12要素配列）を受け取り月インデックスで引く。
      // new Date() はクライアント実行のままなので訪問時の季節を反映する。
      function applyDocumentFlags() {
        const de = document.documentElement;
        const month = new Date().getMonth() + 1;
        de.dataset.season = monthSeasons[month - 1];
        de.classList.add("js");
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          de.classList.add("reduced-motion");
        }
      }
      applyDocumentFlags();
      // 遷移後（DOM swap 直後・描画前）に再適用し、data-season / js フラグを維持する。
      document.addEventListener("astro:after-swap", applyDocumentFlags);
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot name="hero" />
      <div class="main-inner">
        {breadcrumb && <Breadcrumb items={breadcrumb} />}
        <slot />
      </div>
    </main>
    <Footer />
    <script>
      import { initReveal, teardownReveal } from "../scripts/reveal.ts";
      document.addEventListener("astro:page-load", initReveal);
      document.addEventListener("astro:before-swap", teardownReveal);
    </script>
  </body>
</html>
